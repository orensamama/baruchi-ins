# Required for the site's contact forms to send email via Resend (https://resend.com)
# 1. Sign up at resend.com and create an API key.
# 2. Copy this file to ".env" and paste your key below (for local development),
#    and add the same variable in your Vercel project settings (for production).
RESEND_API_KEY=

# Optional: sender address shown in the emails. Defaults to Resend's shared
# testing address (onboarding@resend.dev) if left empty. For reliable delivery
# in production, verify your own domain in Resend and use an address on it,
# e.g. "ברוכי סוכנות לביטוח <forms@yourdomain.co.il>".
RESEND_FROM_EMAIL=

# Required for the contact/portal/mortgage forms to also save each submission
# as a row in the office's internal Supabase "leads" table. Find these under
# Project Settings -> API in the Supabase dashboard. SUPABASE_ANON_KEY here is
# the publishable key (safe to use from a server context) — the "leads" table
# needs a Row Level Security policy that allows INSERT for this key's role, or
# submissions will fail.
SUPABASE_URL=
SUPABASE_ANON_KEY=
